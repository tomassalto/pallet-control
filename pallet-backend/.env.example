APP_NAME="Pallet Control"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- BASE DE DATOS ---
# Local: SQLite (por defecto)
DB_CONNECTION=sqlite

# Producción Railway: MySQL
# DB_CONNECTION=mysql
# DB_HOST=                  # Host de Railway MySQL (lo da Railway en el dashboard)
# DB_PORT=3306
# DB_DATABASE=railway
# DB_USERNAME=root
# DB_PASSWORD=              # Password de Railway MySQL

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
# En producción, después de registrar el superadmin, poner en false:
REGISTRATION_ENABLED=true
# En Railway: cambiar a FILESYSTEM_DISK=r2 y completar las vars R2_* de abajo

# --- CLOUDFLARE R2 (storage de imágenes para producción) ---
# Crear bucket en dash.cloudflare.com → R2 → Create bucket
# Habilitar acceso público en el bucket (o conectar dominio propio)
# Crear API token en R2 → Manage API Tokens → Create API Token
# R2_ENDPOINT = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_URL      = URL pública del bucket (https://pub-xxx.r2.dev  o dominio propio)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_URL=
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@palletcontrol.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# --- OCR de tickets ---
# Opciones para OCR_PROVIDER:
# - azure     ← RECOMENDADO para producción (5.000 requests/mes gratis, ~300ms, sin CPU local)
# - tesseract ← para desarrollo local (requiere binario instalado)
# - paddle    ← alternativa local con PaddleOCR
OCR_PROVIDER=tesseract

# Azure Computer Vision (usar con OCR_PROVIDER=azure)
# Crear recurso gratuito en portal.azure.com → Computer Vision → plan F0
# Documentación: https://learn.microsoft.com/azure/ai-services/computer-vision/
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

OCR_FALLBACK_TESSERACT=true
OCR_PYTHON_BIN=python
# Timeout máximo del request HTTP de subida + OCR (segundos)
OCR_HTTP_TIMEOUT=180
OCR_PROCESS_TIMEOUT=120
PADDLE_OCR_LANG=en
# PADDLE_OCR_SCRIPT=/absolute/path/to/paddle_ocr_ticket.py
