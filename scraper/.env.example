# ── Credenciales Maxi Pedido (comerciante.carrefour.com.ar) ──────────────────
CARREFOUR_EMAIL=tu@email.com
CARREFOUR_DNI=12345678
CARREFOUR_PHONE=2994123456
CARREFOUR_NAME=Nombre Apellido

# Dropdown de sucursal (exactamente como aparece en el sitio)
CARREFOUR_PROVINCIA=NEUQUEN
CARREFOUR_SUCURSAL=Neuquén II - Antártida Argentina 3600

# ── Backend ───────────────────────────────────────────────────────────────────
API_BASE_URL=https://tu-app.onrender.com/api/v1
BOT_SECRET=el-mismo-que-en-render

# ── Opciones del scraper ──────────────────────────────────────────────────────

# Ruta al CSV de EANs (relativa a la carpeta scraper/)
CSV_PATH=../pallet-backend/storage/app/imports/listado.csv

# Pausa entre requests en milisegundos (1500 = 1.5 seg recomendado)
DELAY_MS=1500

# Cuántos productos enviar por batch a la API
BATCH_SIZE=20

# TEST_LIMIT: si está seteado, solo procesa esa cantidad de EANs (para probar)
# Borrar o dejar vacío para procesar todo el CSV
TEST_LIMIT=15

# HEADLESS: "true" para correr sin ventana, "false" para ver el browser
# Poner "false" si el login falla para ver qué pasa
HEADLESS=true

# ── Scheduler (solo si usás scheduler.js) ────────────────────────────────────
# Formato cron: "minuto hora * * día-semana"  (0=dom, 1=lun, 3=mié, 4=jue)
# Ejemplos:
#   0 2 * * 4   → todos los jueves a las 02:00 AM  (default)
#   0 3 * * 3   → todos los miércoles a las 03:00 AM
#   0 2 * * *   → todos los días a las 02:00 AM
SCHEDULE_CRON=0 2 * * 4
